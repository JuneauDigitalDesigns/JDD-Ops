    "@jdd/schema": "github:JuneauDigitalDesigns/jdd-schema#v1.2.0",
    "@phosphor-icons/react": "^2.1.7",
    "@upstash/redis": "^1.38.0",
    "framer-motion": "^11.0.0",
    "geist": "^1.3.1",
    "gsap": "^3.12.5",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
