# Anthropic
ANTHROPIC_API_KEY=

# Resend (master account, reused across every Starter client site for lead email delivery, not used for Growth or Enterprise clients)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Twilio — JDD master account. Used for number provisioning and inbound call routing.
# voiceUrl is set to https://{siteSlug}.vercel.app/api/voice (permanent; no update needed).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Retell — AI agents (numbers are now JDD-owned Twilio numbers, not Retell-managed).
RETELL_API_KEY=
RETELL_LLM_ID=
RETELL_DEFAULT_VOICE_ID=
# Post-call webhook is now set PER CLIENT: onboard.js clones the master post-call
# scenario and writes each clone's webhook into clients/{slug}/.env.local as
# RETELL_POST_CALL_WEBHOOK_URL. A master-level value here is optional/legacy.
RETELL_POST_CALL_WEBHOOK_URL=

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_WORKSPACE_ID=

# GitHub (for creating per-client repos)
GITHUB_TOKEN=
GITHUB_ORG=

# Vercel — required for step 9 (sync env vars to client's deployed project so
# /api/contact has RETELL_API_KEY + TWILIO_NUMBER + RETELL_AGENT_ID for the
# direct Retell callback). Token: vercel.com/account/tokens.
# Team ID: vercel.com/{team}/~/settings → "Team ID" (only if using a team).
# The GitHub-Vercel integration must be authorized once at the org level so
# new client repos are auto-detected.
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Make.com — used by step 8c to clone the post-call master scenario per client.
MAKE_API_KEY=
MAKE_POST_CALL_MASTER_SCENARIO_ID=
# Optional: A2P Messaging Service that holds client local numbers (for SMS sending).
TWILIO_MESSAGING_SERVICE_SID=

# Portal test login — used ONLY for test clients (_e2e* slugs or --test-portal) so you can
# sign into /portal without owning the client's brand.email inbox. Never used for real clients.
PORTAL_TEST_EMAIL=
PORTAL_TEST_PASSWORD=

# Template source — DEPRECATED & UNUSED. Onboarding is local-first: the blank template lives
# in this repo at template/ and is copied per client into clients/{slug}/repo (studio Export or
# `npm run new-client`). onboard.js no longer clones a GitHub template. Leave blank.
TEMPLATE_REPO=
