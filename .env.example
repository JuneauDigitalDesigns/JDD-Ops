# Anthropic
ANTHROPIC_API_KEY=

# Resend (master account, reused across every Starter client site for lead email delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=leads@juneaudigitaldesigns.com

# Twilio — JDD master account. Used for number provisioning and inbound call routing.
# voiceUrl is set to https://{siteSlug}.vercel.app/api/voice (permanent; no update needed).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Retell — AI agents (numbers are now JDD-owned Twilio numbers, not Retell-managed).
RETELL_API_KEY=
RETELL_LLM_ID=
RETELL_DEFAULT_VOICE_ID=
# Webhook URL of the jdd-post-call-log Make scenario — used to wire agents to post-call logging.
RETELL_POST_CALL_WEBHOOK_URL=

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_WORKSPACE_ID=

# GitHub (for creating per-client repos)
GITHUB_TOKEN=
GITHUB_ORG=

# Vercel — required for step 9 (sync env vars to client's deployed project so
# /api/contact has MAKE_WEBHOOK_URL). Token: vercel.com/account/tokens.
# Team ID: vercel.com/{team}/~/settings → "Team ID" (only if using a team).
# The GitHub-Vercel integration must be authorized once at the org level so
# new client repos are auto-detected.
VERCEL_TOKEN=
VERCEL_TEAM_ID=team_ZAOl9EyBWAvQkvE1xAGcyKxg

# Make.com — post-call logging (shared jdd-post-call-log scenario + retell-agent-lookup Data
# Store). onboard.js step 8c upserts each new agent's row (agent_id -> base_id) using these.
MAKE_API_KEY=
MAKE_DATA_STORE_ID=

# Template source — DEPRECATED & UNUSED. Onboarding is local-first: the blank template lives
# in this repo at template/ and is copied per client into clients/{slug}/repo (studio Export or
# `npm run new-client`). onboard.js no longer clones a GitHub template. Leave blank.
TEMPLATE_REPO=
